{
  "name": "lingua-draft",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.3",
  "description": "写作翻译工具 MVP（Electron + React + Vite）",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --port 5173 --strictPort\" \"tsc -p electron/tsconfig.json --watch\" \"wait-on tcp:5173 file:dist-electron/main.js && electron .\"",
    "build": "tsc --noEmit && vite build && tsc -p electron/tsconfig.json",
    "prepare:runtime": "pnpm setup:sidecar && pnpm prepare:models",
    "prepare:models": "python3 scripts/prepare_builtin_models.py",
    "dist:mac": "pnpm prepare:runtime && pnpm build && electron-builder --mac dmg",
    "dist:win": "pnpm prepare:runtime && pnpm build && electron-builder --win nsis",
    "dist:all": "pnpm prepare:runtime && pnpm build && electron-builder -mwl",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test:e2e": "pnpm build && playwright test",
    "setup:sidecar": "sh -c 'PY=$(command -v python3.11 || command -v python3.10 || command -v python3.9 || command -v python3); \"$PY\" -m venv services/ai-sidecar/.venv && services/ai-sidecar/.venv/bin/pip install -r services/ai-sidecar/requirements.txt'"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "35.7.5",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.linguadraft.app",
    "productName": "LinguaDraft",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "services/ai-sidecar/**",
      "local-model/**"
    ],
    "extraResources": [
      {
        "from": "services/ai-sidecar",
        "to": "services/ai-sidecar"
      },
      {
        "from": "local-model",
        "to": "local-model"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
